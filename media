### Unpackerr ###
# Unpackerr extracts rar'd releases on behalf of Sonarr/Radarr so they can
# import them. It has no HTTP API in its default config, so this reads the
# log file directly. Point UNPACKERR_LOG at the install's log path.
cmd_unpackerr() {
    local subcmd="${1:-status}"; shift 2>/dev/null || true
    if [ -z "${UNPACKERR_LOG:-}" ]; then
        echo "❌ UNPACKERR_LOG is not configured. Add it to your config:"
        echo "   UNPACKERR_LOG=\"C:/ProgramData/Unpackerr/unpackerr.log\"  (Windows default)"
        return 1
    fi

    case "$subcmd" in
        status|"")
            local out; out=$(_unpackerr_log 500) || { echo "❌ Could not read $UNPACKERR_LOG"; return 1; }
            if [ -z "$out" ]; then
                echo "❌ Log is empty or unreadable at $UNPACKERR_LOG"
                return 1
            fi
            local last_queue;  last_queue=$(echo "$out"  | grep -E '\[Unpackerr\] Queue:'  | tail -1)
            local last_totals; last_totals=$(echo "$out" | grep -E '\[Unpackerr\] Totals:' | tail -1)
            local last_start;  last_start=$(echo "$out"  | grep -E 'Unpackerr v[0-9].*Starting!' | tail -1)
            if [ -n "$last_start" ]; then
                echo "🟢 $(echo "$last_start" | sed -E 's/^\[INFO\] //')"
            fi
            if [ -n "$last_queue" ]; then
                echo "📦 $last_queue"
            else
                echo "⚠️  No queue activity logged yet. Either the queue is empty or logging hasn't"
                echo "   produced a cycle. Check 'media unpackerr log' for raw tail."
            fi
            [ -n "$last_totals" ] && echo "📊 $last_totals"
            ;;

        recent|activity)
            local n="${1:-25}"
            _unpackerr_log 1000 \
                | grep -E '\[(Sonarr|Radarr|Lidarr|Readarr)\]' \
                | tail -n "$n"
            ;;

        waiting|stuck)
            # Items Sonarr/Radarr marked complete but that Unpackerr couldn't
            # extract. Often the release had no rar, or is already a valid
            # media file and import is blocked for a different reason.
            _unpackerr_log 2000 \
                | grep -E 'Completed item still waiting' \
                | tail -25
            ;;

        log|tail)
            local n="${1:-50}"
            _unpackerr_log "$n"
            ;;

        help|--help|-h)
            cat <<'EOF'
Usage: media unpackerr <subcommand>

  status              Last-known queue counts + totals (default)
  recent [N]          Last N per-item status lines from *arr servers (default 25)
  waiting             Items stuck as "completed but no extractable files"
  log [N]             Raw log tail (default 50 lines)

Unpackerr has no HTTP API; this command reads UNPACKERR_LOG directly.
EOF
            ;;

        *)
            echo "Unknown unpackerr subcommand: $subcmd"
            echo "Run 'media unpackerr help' for usage."
            return 1
            ;;
    esac
}

### Recyclarr ###
# Syncs TRaSH-guide quality profiles and custom formats into Sonarr/Radarr.
# It's a local binary, not a daemon, so we just shell out. Set RECYCLARR_BIN
# to the executable path and RECYCLARR_CONFIG to your recyclarr.yml; the
# config arg is appended automatically for sync/list/delete.
cmd_recyclarr() {
    local subcmd="${1:-status}"; shift 2>/dev/null || true
    local cfg_args=()
    [ -n "${RECYCLARR_CONFIG:-}" ] && cfg_args=(-c "$RECYCLARR_CONFIG")

    case "$subcmd" in
        status|"")
            echo "Binary: ${RECYCLARR_BIN:-recyclarr (from PATH)}"
            echo "Config: ${RECYCLARR_CONFIG:-<default search locations>}"
            echo ""
            _recyclarr_run --version
            ;;

        diff|preview|dry-run)
            # Dry-run sync. Recyclarr prints a colored diff of what *would*
            # change. Always safe to run; makes no API writes.
            _recyclarr_run sync --preview "${cfg_args[@]}" "$@"
            ;;

        sync|apply)
            _recyclarr_run sync "${cfg_args[@]}" "$@"
            ;;

        list)
            local kind="${1:-}"; shift 2>/dev/null || true
            case "$kind" in
                formats|custom-formats|cf)
                    local svc="${1:-sonarr}"
                    _recyclarr_run list custom-formats "$svc"
                    ;;
                profiles|quality-profiles|qp)
                    local svc="${1:-sonarr}"
                    _recyclarr_run list quality-profiles "$svc"
                    ;;
                naming)
                    local svc="${1:-sonarr}"
                    _recyclarr_run list naming "$svc"
                    ;;
                templates)
                    _recyclarr_run config list templates
                    ;;
                "")
                    cat <<'EOF'
Usage: media recyclarr list <kind> [sonarr|radarr]

  formats [svc]     Custom formats in the guide (default: sonarr)
  profiles [svc]    Quality profiles in the guide
  naming [svc]      Media naming formats in the guide
  templates         Local config templates known to recyclarr
EOF
                    ;;
                *)
                    echo "Unknown list kind: $kind"
                    return 1
                    ;;
            esac
            ;;

        config|show)
            # Print the active config file. Matches the 'status' binary/config
            # summary by giving the actual YAML we'll sync.
            if [ -z "${RECYCLARR_CONFIG:-}" ]; then
                echo "❌ RECYCLARR_CONFIG is not set. Nothing to show."
                return 1
            fi
            if [[ "${MEDIA_HOST:-local}" == ssh:* ]]; then
                local host="${MEDIA_HOST#ssh:}"
                if [ "${MEDIA_HOST_OS:-linux}" = "windows" ]; then
                    ssh "$host" "powershell -NoProfile -Command \"Get-Content -LiteralPath '$RECYCLARR_CONFIG'\""
                else
                    ssh "$host" "cat '$RECYCLARR_CONFIG'"
                fi
            else
                cat "$RECYCLARR_CONFIG"
            fi
            ;;

        help|--help|-h)
            cat <<'EOF'
Usage: media recyclarr <subcommand>

  status                  Show binary path, config path, and recyclarr version (default)
  diff                    Dry-run sync (alias: preview): shows changes without applying
  sync                    Apply config to Sonarr/Radarr
  list formats [svc]      List TRaSH custom formats for sonarr|radarr (default: sonarr)
  list profiles [svc]     List TRaSH quality profiles
  list naming [svc]       List media naming formats
  list templates          List local config templates
  config                  Print the active recyclarr.yml

Config:
  RECYCLARR_BIN       Path to the recyclarr binary (default: PATH lookup)
  RECYCLARR_CONFIG    Path to your recyclarr.yml (passed as -c when relevant)
EOF
            ;;

        *)
            echo "Unknown recyclarr subcommand: $subcmd"
            echo "Run 'media recyclarr help' for usage."
            return 1
            ;;
    esac
}

