# Mylar3 wrapper. Response shapes are intentionally inconsistent upstream:
#   getIndex   -> {success, data:[...]}
#   findComic  -> bare JSON array (no success envelope)
#   getWanted  -> {issues:[...]}  (no success key)
#   addComic / delComic -> {success, data/error}
# The parsers below handle each case explicitly rather than assuming a
# uniform envelope.
cmd_comics() {
    local subcmd="${1:-list}"; shift 2>/dev/null || true
    if [ -z "${MYLAR_URL:-}" ] || [ -z "${MYLAR_KEY:-}" ]; then
        echo "❌ MYLAR_URL / MYLAR_KEY not configured. Run 'media setup' or edit the config."
        return 1
    fi

    case "$subcmd" in
        list|ls)
            _mylar "getIndex" | python3 -c "
import sys, json
try: r = json.load(sys.stdin)
except json.JSONDecodeError: print('❌ Non-JSON response from Mylar3'); sys.exit(1)
if not r.get('success'):
    print('❌ API error:', r.get('error')); sys.exit(1)
comics = sorted(r.get('data') or [], key=lambda c: (c.get('name','') or '').lower())
for c in comics:
    status = c.get('status','?')
    icon = '✅' if status == 'Active' else ('⏸️ ' if status == 'Paused' else '⏳')
    name = c.get('name','?')
    year = c.get('year','') or ''
    # Mylar getIndex exposes only 'totalIssues' (maps to comics.Total). There
    # is no per-series owned-count field in the API; computing one would
    # require a getComic call per series, which is too expensive for 'list'.
    total = c.get('totalIssues')
    total_str = str(total) if total not in (None, '') else '?'
    print(f'{icon} {name} ({year})  [{total_str} issues]')
print(f'\nTotal: {len(comics)} series')
" 2>/dev/null
            ;;

        search)
            local query="$*"
            [ -z "$query" ] && { echo "Usage: media comics search <name>"; return 1; }
            local eq
            eq=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$query")
            # findComic returns a bare array; no success envelope
            _mylar "findComic" "&name=$eq" | python3 -c "
import sys, json
try: data = json.load(sys.stdin)
except json.JSONDecodeError: print('❌ Non-JSON response from Mylar3 (ComicVine may be rate-limited or unreachable)'); sys.exit(1)
results = (data if isinstance(data, list) else [])[:10]
for r in results:
    cvid = r.get('comicid','?')
    name = r.get('name','?')
    year = r.get('comicyear','?')
    pub  = r.get('publisher','?')
    iss  = r.get('issues','?')
    # Mylar's haveit is either literal 'No' or the watched series's ComicID
    # (anything non-'No' means already-tracked), not the literal 'Yes'.
    mark = '  ' if r.get('haveit') == 'No' else '✅'
    print(f'{mark} [CV:{cvid}] {name} ({year}) - {pub} [{iss} iss]')
if not results: print('No results found.')
" 2>/dev/null
            ;;

        add)
            local id="${1:-}"
            [ -z "$id" ] && { echo "Usage: media comics add <comicvine_id>"; echo "Run 'media comics search <name>' first to get the ID."; return 1; }
            # Accept either bare numeric id (e.g. 107059) or CV's '4050-107059' prefixed form
            id="${id#4050-}"
            # ARRCLI_CVID must be set on the python3 side of the pipe; setting
            # it on _mylar only exports it to _mylar's own subshell.
            _mylar "addComic" "&id=$id" | ARRCLI_CVID="$id" python3 -c "
import os, sys, json
cvid = os.environ.get('ARRCLI_CVID','?')
try: r = json.load(sys.stdin)
except json.JSONDecodeError: print('❌ Non-JSON response from Mylar3'); sys.exit(1)
if r.get('success'):
    msg = r.get('data') or 'queued'
    print(f'✅ CV:{cvid} - {msg}')
else:
    print('❌ Add failed:', r.get('error')); sys.exit(1)
" 2>/dev/null
            ;;

        missing)
            # getWanted returns {issues:[...]} with no success envelope, and
            # additionally includes an 'annuals' list when ANNUALS_ON is on
            # in Mylar3 config. Merge both so annuals don't silently vanish.
            _mylar "getWanted" | python3 -c "
import sys, json
try: r = json.load(sys.stdin)
except json.JSONDecodeError: print('❌ Non-JSON response from Mylar3'); sys.exit(1)
if not isinstance(r, dict):
    print('❌ Unexpected response shape from getWanted'); sys.exit(1)
issues  = list(r.get('issues')  or [])
annuals = list(r.get('annuals') or [])
for a in annuals:
    a['_annual'] = True
combined = issues + annuals
combined.sort(key=lambda i: ((i.get('ComicName','') or '').lower(), i.get('IssueDate','') or ''))
for i in combined:
    comic = i.get('ComicName','?')
    num   = i.get('Issue_Number','?')
    date  = i.get('IssueDate','')
    tag   = ' [annual]' if i.get('_annual') else ''
    print(f'⏳ {comic} #{num}{tag}  ({date})')
print(f'\nMissing: {len(combined)} wanted ({len(issues)} issues + {len(annuals)} annuals)')
" 2>/dev/null
            ;;

        remove|rm)
            local query="$*"
            [ -z "$query" ] && { echo "Usage: media comics remove <name>"; return 1; }
            # Query goes through an env var to survive apostrophes and other
            # characters that would break triple-quoted string embedding.
            _mylar "getIndex" | ARRCLI_QUERY="$query" python3 -c "
import os, sys, json
query = os.environ.get('ARRCLI_QUERY','').lower()
try: r = json.load(sys.stdin)
except json.JSONDecodeError: print('ERROR:Non-JSON response from Mylar3'); sys.exit(0)
if not r.get('success'): print('ERROR:API error:', r.get('error')); sys.exit(0)
hits = [c for c in (r.get('data') or []) if query in (c.get('name','') or '').lower()]
if not hits: print('ERROR:No match'); sys.exit(0)
if len(hits) > 1:
    for c in hits: print(f'MULTI:{c.get(\"id\",\"?\")}: {c.get(\"name\",\"?\")}')
else:
    c = hits[0]
    print(f'REMOVE:{c.get(\"id\",\"?\")}:{c.get(\"name\",\"?\")}')
" 2>/dev/null | while IFS= read -r line; do
                case "$line" in
                    ERROR:*) echo "${line#ERROR:}" ;;
