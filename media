# Autobrr wrapper. Read-only: writes (adding filters, IRC credentials) stay
# in the web UI - too many edge cases to wrap in shell. In "preinstall"
# posture with zero IRC networks, `status` reports the intentional baseline.
cmd_autobrr() {
    local subcmd="${1:-status}"; shift 2>/dev/null || true
    if [ -z "${AUTOBRR_URL:-}" ] || [ -z "${AUTOBRR_KEY:-}" ]; then
        echo "❌ AUTOBRR_URL / AUTOBRR_KEY not configured. Run 'media setup' or edit the config."
        return 1
    fi

    case "$subcmd" in
        status)
            local cfg filters irc clients releases
            cfg=$(_autobrr "config")
            filters=$(_autobrr "filters")
            irc=$(_autobrr "irc")
            clients=$(_autobrr "download_clients")
            releases=$(_autobrr "release?limit=1")
            ARRCLI_CFG="$cfg" ARRCLI_FILTERS="$filters" ARRCLI_IRC="$irc" \
            ARRCLI_CLIENTS="$clients" ARRCLI_RELEASES="$releases" python3 -c "
