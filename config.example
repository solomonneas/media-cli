# media-cli configuration
# Copy to ~/.config/media-cli/config and fill in your values
# Or run `media setup` for interactive configuration

# Connection: "local" or "ssh:hostname"
# Use "local" if services run on this machine
# Use "ssh:myserver" to run commands over SSH (services bind to localhost on remote)
MEDIA_HOST="local"
MEDIA_HOST_OS="linux"  # "linux" or "windows"

# Core services (required)
SONARR_URL="http://localhost:8989"
SONARR_KEY="your-sonarr-api-key"

RADARR_URL="http://localhost:7878"
RADARR_KEY="your-radarr-api-key"

PROWLARR_URL="http://localhost:9696"
PROWLARR_KEY="your-prowlarr-api-key"

QBIT_URL="http://localhost:8080"
QBIT_USER="admin"
QBIT_PASS="adminadmin"

# Optional services (leave key empty to disable)
BAZARR_URL="http://localhost:6767"
BAZARR_KEY=""

JELLYSEERR_URL="http://localhost:5055"
JELLYSEERR_KEY=""

FLARESOLVERR_URL="http://localhost:8191"
TDARR_URL="http://localhost:8265"

# Unpackerr has no HTTP API; `media unpackerr` reads its log file directly.
# Point this at the log path for your install. Leave empty to disable.
# UNPACKERR_LOG="C:/ProgramData/Unpackerr/unpackerr.log"   # Windows default
# UNPACKERR_LOG="/config/unpackerr/unpackerr.log"          # Linux (varies by install)

# Recyclarr is a local binary, not a daemon. `media recyclarr` shells out.
# RECYCLARR_BIN defaults to "recyclarr" (PATH lookup) if empty.
# RECYCLARR_CONFIG is optional; when set it's passed as `-c` on sync/list.
# RECYCLARR_BIN="C:/ProgramData/Recyclarr/recyclarr.exe"
# RECYCLARR_CONFIG="C:/ProgramData/Recyclarr/recyclarr.yml"

# Readarr (audiobooks instance). Port 8787 is the default.
# READARR_URL="http://localhost:8787"
# READARR_KEY=""
# DEFAULT_AUDIOBOOK_ROOT="G:\\Audiobooks"
# DEFAULT_AUDIOBOOK_QUALITY=2     # "Spoken" profile id (usually 2; eBook is 1)
# DEFAULT_AUDIOBOOK_METADATA=1    # "Standard" metadata profile id

# Readarr (ebooks instance). Port 8788. Second instance of the same binary;
# isolated data dir, separate API key. Community-recommended split since
# Readarr treats books + audiobooks as one library per instance.
# READARR_EBOOKS_URL="http://localhost:8788"
# READARR_EBOOKS_KEY=""
# DEFAULT_EBOOK_ROOT="G:\\Ebooks"
# DEFAULT_EBOOK_QUALITY=1         # "eBook" profile id
# DEFAULT_EBOOK_METADATA=1        # "Standard" metadata profile id

# Lidarr (music). Port 8686. Artist-first model using MusicBrainz metadata.
# LIDARR_URL="http://localhost:8686"
# LIDARR_KEY=""
# DEFAULT_MUSIC_ROOT="I:\\Music"
# DEFAULT_MUSIC_QUALITY=1         # "Any" profile id (Lossless=2, Standard=3)
# DEFAULT_MUSIC_METADATA=1        # "Standard" metadata profile id

# Mylar3 (comics). Port 8090. ComicVine-backed metadata. Not servarr-shaped:
# auth is a ?apikey= query param, not an X-Api-Key header. COMICVINE_API_KEY
# is set inside Mylar3's own config.ini (comicvine_api = ...) rather than
# consumed directly by this CLI - it lives here only as a reference so the
# key is discoverable during setup.
# MYLAR_URL="http://localhost:8090"
# MYLAR_KEY=""
# DEFAULT_COMIC_ROOT="H:\\Comics"
# COMICVINE_API_KEY=""

# Autobrr (IRC announce parser). Port 7474. Stands up empty with zero IRC
# networks; the baseline is "0 releases seen" until a private-tracker invite
# arrives and an IRC network is added via the web UI. Writes (filters, IRC
# credentials) stay in the web UI; this CLI is read-only.
# AUTOBRR_URL="http://localhost:7474"
# AUTOBRR_KEY=""

# Cross-seed (cross-tracker matcher). Port 2468. Webhook-driven daemon that
# matches existing torrents against other trackers via Prowlarr-managed
# Torznab indexers. v6 API exposes ping/webhook/announce/job; everything
# else (recent matches, hit rates) is derived from tailing info.current.log.
# Get the autogenerated key with: cross-seed api-key
# CROSSSEED_URL="http://localhost:2468"
# CROSSSEED_KEY=""
# CROSSSEED_LOGDIR="C:/Users/$USER/AppData/Local/cross-seed/logs"   # Windows default
# CROSSSEED_CONFIG="C:/Users/$USER/AppData/Local/cross-seed/config.js"

# Hunt (Huntarr replacement). Fires targeted missing-item search commands
# on a rate-limited cadence. Huntarr upstream was taken down 2026-02 over
# unpatched security issues; this reimplementation stays inside the *arr
# APIs we already trust.
# HUNT_ENABLED_APPS="sonarr radarr music audiobooks ebooks"
# HUNT_MISSING_PER_CYCLE=5         # Items hunted per app per cycle
# HUNT_API_DELAY_SECONDS=10        # Sleep between apps in the same cycle
# HUNT_MIN_INTERVAL_MINUTES=30     # Per-app cooldown between cycles
# HUNT_FETCH_PAGE_SIZE=200         # First-page size for the random sample
# HUNT_STATE_FILE="C:/ProgramData/arr-cli/hunt-state.json"

# Defaults
DEFAULT_MOVIE_QUALITY=4        # Quality profile ID (4 = HD-1080p typically)
DEFAULT_SHOW_QUALITY=4
DEFAULT_MOVIE_ROOT="/movies"   # Root folder path for new movies
DEFAULT_SHOW_ROOT="/tv"        # Root folder path for new shows

# Optional overrides
# QBIT_HARDEN_EXTRAS="*.exe *.bat"      # Extra extensions to block (see `media qbit harden`)
# TDARR_BOOST_GPU_WORKERS=3             # GPU worker count used by `media tdarr boost on`
