import os, sys, json
name = os.environ.get('ARRCLI_NAME','?')
try: r = json.load(sys.stdin)
except json.JSONDecodeError: print(f'❌ Delete failed: non-JSON response ({name!r})'); sys.exit(1)
if r.get('success'):
