### FlareSolverr ###
# Prowlarr relies on FlareSolverr to pass Cloudflare's "checking your browser"
# challenge on indexers. When Prowlarr tests start failing mysteriously, the
# usual culprit is FlareSolverr being unreachable or its session cache gone
# stale. These commands give you a fast way to triage without leaving the CLI.

cmd_flaresolverr() {
    local subcmd="${1:-status}"; shift 2>/dev/null || true
    local url="${FLARESOLVERR_URL:-}"
    if [ -z "$url" ]; then
        echo "❌ FLARESOLVERR_URL is not configured. Run 'media setup' or edit the config."
        return 1
    fi

    case "$subcmd" in
        status|"")
            _flaresolverr_get | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(f'✅ FlareSolverr {d.get(\"version\",\"?\")} — {d.get(\"msg\",\"\")}')
    ua = d.get('userAgent','')
    if ua: print(f'   UA: {ua[:100]}')
except Exception as e:
    print(f'❌ Could not parse response: {e}')
    sys.exit(1)
" 2>/dev/null || { echo "❌ FlareSolverr not reachable at $url"; return 1; }
            echo ""
            cmd_flaresolverr sessions
            ;;

        sessions|ls)
            local resp
            resp=$(_flaresolverr_post '{"cmd":"sessions.list"}') || { echo "❌ Request failed"; return 1; }
            echo "$resp" | python3 -c "
import sys, json
d = json.load(sys.stdin)
sessions = d.get('sessions', [])
print(f'Active sessions: {len(sessions)}')
for s in sessions:
    print(f'  - {s}')
" 2>/dev/null
            ;;

        test|solve)
            local target="${1:-}"
            if [ -z "$target" ]; then
                echo "Usage: media flaresolverr test <url>"
                echo ""
                echo "Fires a request.get through FlareSolverr and reports whether the"
                echo "challenge was solved. Use an indexer URL known to sit behind"
                echo "Cloudflare (e.g. https://1337x.to) to verify Prowlarr will work."
                return 1
            fi
            # Short escape — Python builds a safe JSON body with the user-supplied URL.
            local body
            body=$(python3 -c "import json,sys; print(json.dumps({'cmd':'request.get','url':sys.argv[1],'maxTimeout':60000}))" "$target")
            echo "Solving challenge at $target (up to 60s)..."
            local resp
            resp=$(_flaresolverr_post "$body") || { echo "❌ FlareSolverr request failed"; return 1; }
            echo "$resp" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status  = d.get('status','?')
message = d.get('message','')
elapsed = d.get('startTimestamp') and d.get('endTimestamp') and (d['endTimestamp']-d['startTimestamp']) or '?'
sol = d.get('solution',{}) or {}
code    = sol.get('status','?')
final   = sol.get('url','')
ua      = sol.get('userAgent','')
icon = '✅' if status == 'ok' else '❌'
print(f'{icon} {status} — {message}')
print(f'   HTTP: {code}')
print(f'   Final URL: {final}')
if isinstance(elapsed, (int, float)):
    print(f'   Elapsed: {elapsed} ms')
if ua:
    print(f'   UA: {ua[:100]}')
" 2>/dev/null
            ;;

        clear|destroy)
            # Destroy a single session, or all sessions when no id given.
            local sid="${1:-}"
            if [ -n "$sid" ]; then
                _flaresolverr_post "{\"cmd\":\"sessions.destroy\",\"session\":\"$sid\"}" >/dev/null && \
                    echo "✅ Destroyed session $sid" || { echo "❌ Failed to destroy session $sid"; return 1; }
                return 0
            fi
            local sessions
            sessions=$(_flaresolverr_post '{"cmd":"sessions.list"}' | python3 -c "
import sys, json
for s in json.load(sys.stdin).get('sessions', []):
    print(s)
" 2>/dev/null)
            if [ -z "$sessions" ]; then
                echo "No active sessions."
                return 0
            fi
            local n=0
            while IFS= read -r sid; do
                [ -z "$sid" ] && continue
                _flaresolverr_post "{\"cmd\":\"sessions.destroy\",\"session\":\"$sid\"}" >/dev/null && n=$((n+1))
            done <<< "$sessions"
            echo "✅ Destroyed $n session(s)"
            ;;

        help|--help|-h)
            cat <<'EOF'
Usage: media flaresolverr <subcommand>

  status             Show version, ready message, active session count (default)
  sessions           List active FlareSolverr sessions
  test <url>         Solve a Cloudflare challenge for a URL (triage Prowlarr failures)
  clear [session]    Destroy all sessions, or just the one named

Aliases: 'flare' for the command, 'ls' for sessions, 'solve' for test, 'destroy' for clear.
EOF
            ;;

        *)
            echo "Unknown flaresolverr subcommand: $subcmd"
            echo "Run 'media flaresolverr help' for usage."
            return 1
            ;;
    esac
}

### qBittorrent malware hardening ###
# Sets qB's global `excluded_file_names` preference to block common malware
# extensions from extracting to disk. Originally motivated by LummaStealer-class
# payloads distributed in poisoned video releases (fake .exe / .scr files named
# to look like the episode/movie).
#
# Default block list deliberately omits .exe and .bat — some users keep those
# for legit non-media downloads. Add them yourself if you're media-only:
#   QBIT_HARDEN_EXTRAS="*.exe *.bat" media qbit harden on
#
# To disable:  media qbit harden off
# To inspect: media qbit harden status

QBIT_HARDEN_DEFAULT="*.scr *.pif *.vbs *.wsf *.hta *.lnk *.jar *.com *.msi *.js *.jse *.vbe *.ps1 *.psm1 *.reg *.dll"

cmd_qbit() {
    local subcmd="${1:-}"; shift 2>/dev/null || true

    case "$subcmd" in
        harden)
            local action="${1:-on}"
            case "$action" in
                on|enable)
                    # Read existing excluded_file_names and merge OUR patterns in — do not
                    # clobber user-configured exclusions. qBittorrent wants the list
                    # newline-separated; using python's json.dumps handles escaping.
                    local prefs
                    prefs=$(_qbit "app/preferences") || { echo "❌ Could not read qBittorrent preferences"; return 1; }
                    local json
                    json=$(echo "$prefs" | QB_DEFAULTS="$QBIT_HARDEN_DEFAULT" QB_EXTRAS="${QBIT_HARDEN_EXTRAS:-}" python3 -c "
import sys, os, json
prefs = json.load(sys.stdin)
existing = [x.strip() for x in (prefs.get('excluded_file_names','') or '').split('\n') if x.strip()]
ours = os.environ['QB_DEFAULTS'].split() + os.environ['QB_EXTRAS'].split()
# Preserve user patterns first, append ours, de-dupe while keeping order.
merged = list(dict.fromkeys(existing + ours))
print(json.dumps({
    'excluded_file_names_enabled': True,
    'excluded_file_names': '\n'.join(merged),
}))
") || { echo "❌ Failed to build preferences payload"; return 1; }
                    local added
                    added=$(echo "$prefs" | QB_DEFAULTS="$QBIT_HARDEN_DEFAULT" QB_EXTRAS="${QBIT_HARDEN_EXTRAS:-}" python3 -c "
import sys, os, json
prefs = json.load(sys.stdin)
existing = set(x.strip() for x in (prefs.get('excluded_file_names','') or '').split('\n') if x.strip())
ours = os.environ['QB_DEFAULTS'].split() + os.environ['QB_EXTRAS'].split()
new = [p for p in ours if p not in existing]
print(' '.join(new) if new else '(already present)')
")
                    if _qbit_set_pref "$json" >/dev/null; then
                        echo "✅ qBittorrent malware hardening enabled"
                        echo "   Added: $added"
                        echo "   Existing user exclusions preserved."
                        echo ""
                        echo "   Note: this is layer 2 of 3. For full protection on Windows hosts:"
                        echo "   - Defender scan on downloads dir (Set-MpPreference)"
                        echo "   - qB autorun hook to delete executables in media categories"
                        echo "   See: https://github.com/solomonneas/media-cli#malware-hardening"
                    else
                        echo "❌ Failed to update qBittorrent preferences"
                        return 1
                    fi
                    ;;
                off|disable)
                    # Remove ONLY our patterns; leave user-added exclusions in place.
                    local prefs
                    prefs=$(_qbit "app/preferences") || { echo "❌ Could not read qBittorrent preferences"; return 1; }
                    local json
                    json=$(echo "$prefs" | QB_DEFAULTS="$QBIT_HARDEN_DEFAULT" QB_EXTRAS="${QBIT_HARDEN_EXTRAS:-}" python3 -c "
import sys, os, json
prefs = json.load(sys.stdin)
existing = [x.strip() for x in (prefs.get('excluded_file_names','') or '').split('\n') if x.strip()]
ours = set(os.environ['QB_DEFAULTS'].split() + os.environ['QB_EXTRAS'].split())
remaining = [x for x in existing if x not in ours]
# Disable the toggle entirely only if nothing user-authored is left.
print(json.dumps({
    'excluded_file_names_enabled': bool(remaining),
    'excluded_file_names': '\n'.join(remaining),
}))
") || { echo "❌ Failed to build preferences payload"; return 1; }
                    if _qbit_set_pref "$json" >/dev/null; then
                        local remaining_count=0
                        remaining_count=$(echo "$json" | python3 -c "import sys,json; n=json.load(sys.stdin)['excluded_file_names']; print(len([x for x in n.split('\n') if x.strip()]))" 2>/dev/null) || remaining_count=0
                        echo "⚠️  qBittorrent malware hardening DISABLED (our patterns removed)"
                        if [ "${remaining_count:-0}" -gt 0 ]; then
                            echo "   $remaining_count user-configured exclusion(s) preserved."
                        else
                            echo "   No other exclusions configured; feature toggle turned off."
                        fi
                    else
                        echo "❌ Failed to update qBittorrent preferences"
                        return 1
                    fi
                    ;;
                status)
                    _qbit "app/preferences" | QB_DEFAULTS="$QBIT_HARDEN_DEFAULT" QB_EXTRAS="${QBIT_HARDEN_EXTRAS:-}" python3 -c "
import sys, os, json
p = json.load(sys.stdin)
enabled = p.get('excluded_file_names_enabled', False)
patterns = [x.strip() for x in (p.get('excluded_file_names','') or '').split('\n') if x.strip()]
ours = set(os.environ['QB_DEFAULTS'].split() + os.environ['QB_EXTRAS'].split())
hardening_active = enabled and ours.issubset(set(patterns))
state = '✅ ENABLED' if hardening_active else '❌ DISABLED'
print(f'Malware hardening: {state}')
print(f'Toggle: excluded_file_names_enabled={enabled}')
print(f'Total patterns: {len(patterns)}')
ours_present = [p for p in patterns if p in ours]
user_present = [p for p in patterns if p not in ours]
if ours_present:
    print(f'  Our patterns ({len(ours_present)}): {\" \".join(ours_present)}')
if user_present:
    print(f'  User patterns ({len(user_present)}): {\" \".join(user_present)}')
" 2>/dev/null || { echo "❌ Could not read qBittorrent preferences"; return 1; }
                    ;;
                *)
                    echo "Usage: media qbit harden [on|off|status]"
                    return 1
                    ;;
            esac
            ;;
        ""|help)
            cat <<EOF
Usage: media qbit <subcommand>

  harden on         Block malware extensions from extracting (recommended, default ON after setup)
  harden off        Allow all file extensions
  harden status     Show current hardening state + blocked extensions

Override blocked list:
  QBIT_HARDEN_EXTRAS="*.exe *.bat" media qbit harden on
EOF
            ;;
        *)
            echo "Unknown qbit subcommand: $subcmd"
            echo "Run 'media qbit' for help."
            return 1
            ;;
    esac
}

cmd_tdarr() {
    local tdarr_url="${TDARR_URL:-http://localhost:8265}"
    local subcmd="${1:-status}"; shift 2>/dev/null || true

    _tdarr_get() { _curl "${tdarr_url}/api/v2/$1" ""; }
    _tdarr_post() {
        if [[ "${MEDIA_HOST:-local}" == ssh:* ]]; then
            local host="${MEDIA_HOST#ssh:}"
            ssh "$host" "curl -sf --max-time 15 -X POST -H \"Content-Type: application/json\" -d \"{}\" \"${tdarr_url}/api/v2/$1\"" 2>/dev/null
        else
            curl -sf --max-time 15 -X POST -H "Content-Type: application/json" -d "{}" "${tdarr_url}/api/v2/$1" 2>/dev/null
        fi
    }
    # POST with arbitrary JSON body. Delegates to _post_json so Windows SSH
    # hosts get the PowerShell Invoke-RestMethod path (curl stdin over SSH
    # silently drops the body on Windows).
    _tdarr_post_json() {
        local endpoint="$1"; local body="$2"
        _post_json "${tdarr_url}/api/v2/$endpoint" "$body" 15
    }
    # Discover the first node ID — works for single-node setups (most people)
    _tdarr_first_node() {
        _tdarr_get "get-nodes" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for nid, node in d.items():
    if isinstance(node, dict) and 'workers' in node:
        print(nid); break
" 2>/dev/null
    }

    case "$subcmd" in
        status)
            echo "=== Tdarr Status ==="
            local ver
            ver=$(_tdarr_get "status" | python3 -c "import sys,json; d=json.load(sys.stdin); print(f'v{d[\"version\"]} ({d[\"os\"]})')" 2>/dev/null) || { echo "❌ Tdarr not reachable at $tdarr_url"; return 1; }
            echo "✅ Tdarr $ver"
            echo ""

            _tdarr_post "get-res-stats" | python3 -c "
import sys,json
d = json.load(sys.stdin)
p = d.get('process',{}); o = d.get('os',{})
print('=== Server Resources ===')
print(f'  CPU:    {o.get(\"cpuPerc\",\"?\"):>6}%')
print(f'  RAM:    {o.get(\"memUsedGB\",\"?\")}/{o.get(\"memTotalGB\",\"?\")} GB')
print(f'  Heap:   {p.get(\"heapUsedMB\",\"?\")} MB / {p.get(\"heapTotalMB\",\"?\")} MB')
print(f'  Uptime: {int(p.get(\"uptime\",0))//3600}h {(int(p.get(\"uptime\",0))%3600)//60}m')
" 2>/dev/null

            echo ""
            _tdarr_post "get-db-statuses" | python3 -c "
import sys,json
d = json.load(sys.stdin)
print('=== Database ===')
for k in ['LibrarySettingsJSONDB','FileJSONDB','StagedJSONDB','FlowsJSONDB']:
    info = d.get(k,{})
    label = k.replace('JSONDB','').replace('Settings','')
    cnt = info.get('totalCount',0)
    act = info.get('type','')
    act_str = f' - {act}' if act else ''
    print(f'  {label:<12} {cnt:>5} items{act_str}')
" 2>/dev/null

            echo ""
            cmd_tdarr workers
            ;;

        queue)
            echo "=== Tdarr Queue ==="
            _tdarr_post "get-db-statuses" | python3 -c "
import sys,json
d = json.load(sys.stdin)
files  = d.get('FileJSONDB',{})
staged = d.get('StagedJSONDB',{})
print(f'  Files indexed:  {files.get(\"totalCount\",0)}')
print(f'  Staged (queue): {staged.get(\"totalCount\",0)}')
act = staged.get('type','')
if act: print(f'  Status: {act}')
" 2>/dev/null
            ;;

        boost)
            # `boost on`  = disable schedule, max GPU workers (default 3, override: TDARR_BOOST_GPU_WORKERS=N)
            # `boost off` = re-enable schedule (restore time-based rotation)
            # no arg     = show current boost state
            local action="${1:-status}"
            local nid; nid=$(_tdarr_first_node)
            [ -z "$nid" ] && { echo "❌ No Tdarr nodes found at $tdarr_url"; return 1; }

            case "$action" in
                on)
                    local n="${TDARR_BOOST_GPU_WORKERS:-3}"
                    local body="{\"data\":{\"nodeID\":\"$nid\",\"nodeUpdates\":{\"scheduleEnabled\":false,\"workerLimits\":{\"transcodegpu\":$n}}}}"
                    if _tdarr_post_json "update-node" "$body" >/dev/null; then
                        echo "🚀 Tdarr boost ON — schedule disabled, $n GPU workers"
                    else
                        echo "❌ Failed to enable boost"; return 1
                    fi
                    ;;
                off)
                    local body="{\"data\":{\"nodeID\":\"$nid\",\"nodeUpdates\":{\"scheduleEnabled\":true}}}"
                    if _tdarr_post_json "update-node" "$body" >/dev/null; then
                        echo "✅ Tdarr boost OFF — schedule re-enabled"
                    else
                        echo "❌ Failed to disable boost"; return 1
                    fi
                    ;;
                status|"")
                    _tdarr_get "get-nodes" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for nid, node in d.items():
    if not isinstance(node, dict) or 'workers' not in node: continue
    wl = node.get('workerLimits', {})
    sched = node.get('scheduleEnabled', False)
    mode = '🚀 BOOST (schedule off)' if not sched else '⏰ SCHEDULED'
    print(f\"Node: {node.get('nodeName', nid)}  [{mode}]\")
    print(f\"  GPU workers: {wl.get('transcodegpu','?')}  CPU workers: {wl.get('transcodecpu','?')}\")
" 2>/dev/null
                    ;;
                *) echo "Usage: media tdarr boost [on|off|status]"; return 1 ;;
            esac
            ;;

        schedule)
            # `schedule on`  = enable time-based schedule
            # `schedule off` = disable (static workerLimits take over)
            local action="${1:-}"
            local nid; nid=$(_tdarr_first_node)
            [ -z "$nid" ] && { echo "❌ No Tdarr nodes found at $tdarr_url"; return 1; }

            case "$action" in
                on|enable)
                    local body="{\"data\":{\"nodeID\":\"$nid\",\"nodeUpdates\":{\"scheduleEnabled\":true}}}"
                    _tdarr_post_json "update-node" "$body" >/dev/null && echo "✅ Schedule enabled" || { echo "❌ Failed"; return 1; }
                    ;;
                off|disable)
                    local body="{\"data\":{\"nodeID\":\"$nid\",\"nodeUpdates\":{\"scheduleEnabled\":false}}}"
                    _tdarr_post_json "update-node" "$body" >/dev/null && echo "✅ Schedule disabled (static worker limits active)" || { echo "❌ Failed"; return 1; }
                    ;;
                *) echo "Usage: media tdarr schedule [on|off]"; return 1 ;;
            esac
            ;;

        workers)
            # If no args → per-worker status (existing behavior).
            # If `workers set <type> <n>` → update workerLimits[type] to n.
            #   types: transcodegpu, transcodecpu, healthcheckgpu, healthcheckcpu
            if [ "${1:-}" = "set" ]; then
                local wtype="${2:-}"; local count="${3:-}"
                case "$wtype" in
                    transcodegpu|transcodecpu|healthcheckgpu|healthcheckcpu) ;;
                    *) echo "Usage: media tdarr workers set <transcodegpu|transcodecpu|healthcheckgpu|healthcheckcpu> <n>"; return 1 ;;
                esac
                [[ "$count" =~ ^[0-9]+$ ]] || { echo "Worker count must be a non-negative integer"; return 1; }
                local nid; nid=$(_tdarr_first_node)
                [ -z "$nid" ] && { echo "❌ No Tdarr nodes found at $tdarr_url"; return 1; }
                local body="{\"data\":{\"nodeID\":\"$nid\",\"nodeUpdates\":{\"workerLimits\":{\"$wtype\":$count}}}}"
                _tdarr_post_json "update-node" "$body" >/dev/null && echo "✅ $wtype → $count" || { echo "❌ Failed to update"; return 1; }
                return 0
            fi

            echo "=== Tdarr Workers ==="
            _tdarr_get "get-nodes" | python3 -c "
import sys,json
d = json.load(sys.stdin)
total = 0; active = 0
for nid, node in d.items():
    if not isinstance(node, dict) or 'workers' not in node: continue
    workers = node.get('workers', {})
    node_total = len(workers)
    node_active = sum(1 for w in workers.values() if isinstance(w,dict) and not w.get('idle',True))
    total += node_total; active += node_active
    print(f'Node: {node.get(\"nodeName\", nid)}  ({node_active}/{node_total} workers active)')
    for wid, w in workers.items():
        if not isinstance(w, dict): continue
        wtype = w.get('workerType','?')
        if w.get('idle', True):
            print(f'  ⏸️  {wid} [{wtype}] idle')
        else:
            pct = w.get('percentage', 0)
            orig = w.get('originalfileSizeInGbytes', 0)
            out  = w.get('outputFileSizeInGbytes', 0)
            file = w.get('file','?')
            fname = file.replace('\\\\','/').split('/')[-1][:65] if isinstance(file,str) else '?'
            eta  = w.get('ETA','?')
            fps  = w.get('fps','')
            fps_str = f' @ {fps}fps' if fps else ''
            reduction = round((1 - out/orig)*100, 1) if orig > 0 and out > 0 else 0
            print(f'  ⚙️  {wid} [{wtype}] {pct:.1f}%{fps_str}')
            print(f'     {fname}')
            print(f'     {orig:.2f}GB -> {out:.2f}GB ({reduction:.1f}% smaller) ETA: {eta}')
print(f'\nTotal: {active} active / {total} workers')
" 2>/dev/null
            ;;

        *) echo "Usage: media tdarr [status|workers|queue|boost|schedule]" ;;
    esac
}

cmd_help() {
    cat <<'EOF'
media-cli - CLI for the *arr media stack

USAGE: media <command> [subcommand] [args...]

SETUP:
  setup                    Interactive configuration wizard

LIBRARY:
  status                   Service health + library counts + active downloads
  movies list|search|add|remove|missing
  shows  list|search|add|remove

DOWNLOADS:
  downloads [list|active|pause|resume|remove]
  queue                    Sonarr/Radarr download queues
  wanted                   Missing episodes and movies

MONITORING:
  calendar [days]          Upcoming releases (default: 7)
  history [sonarr|radarr|all] [limit]
  indexers                 List Prowlarr indexers
  refresh [movies|shows|all]

SUBTITLES (Bazarr):
  subs [status|history]

REQUESTS (Jellyseerr):
  requests [list|trending|users]

TRANSCODING (Tdarr):
  tdarr [status]           Server status, resources, active workers
  tdarr workers            Per-worker progress (file, %, fps, ETA, size savings)
  tdarr workers set <type> <n>  Update workerLimits (transcodegpu/cpu, healthcheckgpu/cpu)
  tdarr queue              Items queued for processing
  tdarr boost [on|off]     Toggle max GPU workers + disable schedule (off = restore schedule)
  tdarr schedule [on|off]  Enable/disable Tdarr's time-based worker schedule

SECURITY (qBittorrent):
  qbit harden [on|off|status]   Block malware-style file extensions from extracting
                                (ENABLED by default after 'media setup')

CLOUDFLARE (FlareSolverr):
  flaresolverr [status]    Version + active session count
  flaresolverr sessions    List active solver sessions
  flaresolverr test <url>  Solve a Cloudflare challenge (triage Prowlarr failures)
  flaresolverr clear [id]  Destroy all sessions, or a specific one

REQUIREMENTS:
  bash, curl, python3, ssh (for remote mode)

CONFIG: ~/.config/media-cli/config
EOF
}

# ── Main ────────────────────────────────────────────────────────────────────
cmd="${1:-help}"; shift 2>/dev/null || true

# Setup doesn't need config
[ "$cmd" = "setup" ] && { cmd_setup; exit 0; }
[ "$cmd" = "help" ] || [ "$cmd" = "--help" ] || [ "$cmd" = "-h" ] && { cmd_help; exit 0; }

_load_config

case "$cmd" in
    status)           cmd_status "$@" ;;
    movies)           cmd_movies "$@" ;;
    shows)            cmd_shows "$@" ;;
    downloads|dl)     cmd_downloads "$@" ;;
    queue)            cmd_queue "$@" ;;
    wanted)           cmd_wanted "$@" ;;
    calendar|cal)     cmd_calendar "$@" ;;
    history)          cmd_history "$@" ;;
    indexers)         cmd_indexers "$@" ;;
    refresh)          cmd_refresh "$@" ;;
    subs|subtitles)   cmd_subs "$@" ;;
    requests|req)     cmd_requests "$@" ;;
    tdarr|transcode)  cmd_tdarr "$@" ;;
    qbit|qbittorrent) cmd_qbit "$@" ;;
    flaresolverr|flare|cf)
                      cmd_flaresolverr "$@" ;;
    *)                echo "Unknown: $cmd"; cmd_help; exit 1 ;;
esac
